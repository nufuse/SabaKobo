{
  "name": "sabakobo",
  "productName": "SabaKobo",
  "version": "0.3.0",
  "description": "鯖工房 — Minecraftサーバーの作成・起動・管理デスクトップアプリ",
  "main": "src/main.js",
  "author": "yuyu",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "test": "node scripts/dev-test.js"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "app.sabakobo.desktop",
    "productName": "SabaKobo",
    "files": [
      "src/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "nufuse",
      "repo": "SabaKobo"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "SabaKobo-Setup-${version}.${ext}",
      "shortcutName": "鯖工房"
    }
  }
}
